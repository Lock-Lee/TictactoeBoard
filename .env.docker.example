# ============================================
# Docker Environment Configuration
# ============================================
# Copy this file to .env.docker and fill in the values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=erp_db

# ============================================
# Backend Configuration
# ============================================
# JWT Configuration (REQUIRED - generate a strong random string min 64 chars)
JWT_SECRET=CHANGE_ME_USE_openssl_rand_-base64_64_TO_GENERATE
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=https://your-domain.com

# App Info
APP_NAME="Tic-Tac-Toe Game"
APP_VERSION=1.0.0

# ============================================
# Frontend Configuration
# ============================================
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_APP_NAME="Tic-Tac-Toe Game"
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================
# Optional: External Services
# ============================================
# Redis (if using external Redis)
# REDIS_URL=redis://redis:6379

# ============================================
# SSL/TLS (for production with nginx)
# ============================================
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem
