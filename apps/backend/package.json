{
  "name": "@repo/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "lint": "biome check --write .",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:create": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "bun prisma/seed.ts",
    "clean": "rm -rf dist node_modules .turbo",
    "test": "bun test tests/*.unit.test.ts 2>/dev/null || echo 'No unit tests to run (E2E tests require: bun run test:e2e)'",
    "test:e2e": "bun test tests/*.e2e.test.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/jwt": "^1.1.1",
    "@elysiajs/swagger": "^1.1.5",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@prisma/client-runtime-utils": "^7.2.0",
    "@repo/shared-types": "workspace:*",
    "bcrypt": "^5.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "effect": "^3.11.7",
    "elysia": "^1.1.23",
    "ioredis": "^5.4.1",
    "jose": "^6.1.3",
    "pg": "^8.16.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.4.5",
    "@repo/tsconfig": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/bun": "^1.1.13",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.1.38",
    "prisma": "^7.2.0",
    "typescript": "^5.7.2"
  }
}
