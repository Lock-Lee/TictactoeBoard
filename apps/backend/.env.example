# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL via Docker)
DATABASE_URL="postgresql://ttt_user:ttt_password@localhost:5432/ttt_db"

# JWT - IMPORTANT: Generate a strong random secret for production!
# Use: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Redis (optional - comment out if not using)
# REDIS_URL=redis://localhost:6379

# CORS - Set to your frontend domain in production
CORS_ORIGIN=http://localhost:3001

# Application
APP_NAME="Tic-Tac-Toe Game"
APP_VERSION=0.0.0
